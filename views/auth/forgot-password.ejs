<%- include('../partials/header', { title: 'Forgot Password', error: error, success: success }) %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <i class="fas fa-lock" style="font-size:2.5rem;color:var(--primary);display:block;margin-bottom:12px"></i>
      <h2>Forgot Password?</h2>
      <p>Enter your email and we'll send you a reset link</p>
    </div>
    <form action="/auth/forgot-password" method="POST" class="auth-form">
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" placeholder="your@email.com" required/>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Send Reset Link</button>
    </form>
    <p class="auth-switch"><a href="/auth/login">Back to Login</a></p>
  </div>
</div>

<%- include('../partials/footer') %>
