<%- include('../partials/header', { title: 'My Profile', error: error, success: success }) %>

<div class="page-container">
  <div class="profile-page">
    <div class="profile-sidebar">
      <div class="avatar-circle"><%= user.name.charAt(0).toUpperCase() %></div>
      <h2><%= user.name %></h2>
      <span class="badge" style="margin-bottom:8px"><%= user.role %></span>
      <% if (user.role === 'organizer' && user.organization) { %>
        <p style="font-weight:600;color:var(--primary)"><i class="fas fa-building"></i> <%= user.organization %></p>
        <% if (user.orgWebsite) { %><a href="<%= user.orgWebsite %>" target="_blank" style="font-size:0.85rem"><i class="fas fa-globe"></i> Website</a><% } %>
      <% } %>
      <p style="margin-top:8px"><%= user.bio || 'No bio yet' %></p>
      <% if (user.college) { %><p><i class="fas fa-university"></i> <%= user.college %></p><% } %>
      <% if (user.skills && user.skills.length) { %>
        <div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:8px">
          <% user.skills.forEach(s => { %><span class="skill-chip"><%= s %></span><% }) %>
        </div>
      <% } %>
      <% if (user.resume) { %><a href="<%= user.resume %>" target="_blank" class="btn btn-outline btn-sm" style="margin-top:12px">View Resume</a><% } %>
      <a href="/dashboard" class="btn btn-primary btn-sm" style="margin-top:8px"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
    </div>

    <div class="profile-main">
      <h3>Edit Profile</h3>
      <form action="/auth/profile" method="POST" enctype="multipart/form-data" class="form">
        <div class="form-row">
          <div class="form-group">
            <label>Full Name</label>
            <input type="text" name="name" value="<%= user.name %>" required/>
          </div>
          <% if (user.role !== 'organizer') { %>
          <div class="form-group">
            <label>College / University</label>
            <input type="text" name="college" value="<%= user.college %>"/>
          </div>
          <% } %>
        </div>
        <div class="form-group">
          <label>Bio</label>
          <textarea name="bio" rows="3"><%= user.bio %></textarea>
        </div>
        <% if (user.role !== 'organizer') { %>
        <div class="form-group">
          <label>Skills (comma separated)</label>
          <input type="text" name="skills" value="<%= user.skills.join(', ') %>" placeholder="JavaScript, Python, ML..."/>
        </div>
        <div class="form-group">
          <label>Upload Resume (PDF)</label>
          <input type="file" name="resume" accept=".pdf,.doc,.docx"/>
        </div>
        <% } %>
        <% if (user.role === 'organizer') { %>
        <div class="form-section" style="margin-top:8px">
          <h3 style="font-size:1rem;border-bottom:2px solid var(--primary);padding-bottom:8px;color:var(--primary)">Organization Details</h3>
          <div class="form-group">
            <label>Organization Name</label>
            <input type="text" name="organization" value="<%= user.organization %>"/>
          </div>
          <div class="form-group">
            <label>Website</label>
            <input type="text" name="orgWebsite" value="<%= user.orgWebsite %>"/>
          </div>
          <div class="form-group">
            <label>About Organization</label>
            <textarea name="orgDescription" rows="3"><%= user.orgDescription %></textarea>
          </div>
        </div>
        <% } %>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
