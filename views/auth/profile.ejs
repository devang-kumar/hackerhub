<%- include('../partials/header', { title: 'My Profile' }) %>

<div class="page-container">
  <div class="profile-page">
    <div class="profile-sidebar">
      <div class="avatar-circle"><%= user.name.charAt(0).toUpperCase() %></div>
      <h2><%= user.name %></h2>
      <span class="badge"><%= user.role %></span>
      <p><%= user.bio || 'No bio yet' %></p>
      <% if (user.college) { %><p><i class="fas fa-university"></i> <%= user.college %></p><% } %>
      <% if (user.resume) { %><a href="<%= user.resume %>" target="_blank" class="btn btn-outline btn-sm">View Resume</a><% } %>
    </div>
    <div class="profile-main">
      <h3>Edit Profile</h3>
      <form action="/auth/profile" method="POST" enctype="multipart/form-data" class="form">
        <div class="form-row">
          <div class="form-group">
            <label>Full Name</label>
            <input type="text" name="name" value="<%= user.name %>" required/>
          </div>
          <div class="form-group">
            <label>College / University</label>
            <input type="text" name="college" value="<%= user.college %>"/>
          </div>
        </div>
        <div class="form-group">
          <label>Bio</label>
          <textarea name="bio" rows="3"><%= user.bio %></textarea>
        </div>
        <div class="form-group">
          <label>Skills (comma separated)</label>
          <input type="text" name="skills" value="<%= user.skills.join(', ') %>" placeholder="JavaScript, Python, ML..."/>
        </div>
        <div class="form-group">
          <label>Upload Resume (PDF)</label>
          <input type="file" name="resume" accept=".pdf,.doc,.docx"/>
        </div>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
