<%- include('../partials/header', { title: 'Create Competition', error: messages.error }) %>

<div class="page-container">
  <div class="form-page">
    <h1>Post a Competition</h1>
    <form action="/competitions/create" method="POST" enctype="multipart/form-data" class="form" id="compForm">

      <div class="form-section">
        <h3>Basic Info</h3>
        <div class="form-group">
          <label>Competition Title *</label>
          <input type="text" name="title" placeholder="e.g. National Hackathon 2026" required/>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Type *</label>
            <select name="type">
              <option value="hackathon">Hackathon</option>
              <option value="quiz">Quiz</option>
              <option value="coding">Coding Challenge</option>
              <option value="case-study">Case Study</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label>Mode *</label>
            <select name="mode">
              <option value="online">Online</option>
              <option value="offline">Offline</option>
              <option value="hybrid">Hybrid</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Description *</label>
          <textarea name="description" rows="5" placeholder="Describe your competition..." required></textarea>
        </div>
        <div class="form-group">
          <label>Eligibility</label>
          <input type="text" name="eligibility" placeholder="e.g. Open for all college students"/>
        </div>
        <div class="form-group">
          <label>Tags (comma separated)</label>
          <input type="text" name="tags" placeholder="AI, ML, Web Dev, Finance..."/>
        </div>
        <div class="form-group">
          <label>Banner Image</label>
          <input type="file" name="banner" accept="image/*"/>
        </div>
      </div>

      <div class="form-section">
        <h3>Team & Dates</h3>
        <div class="form-row">
          <div class="form-group">
            <label>Min Team Size</label>
            <input type="number" name="teamMin" value="1" min="1"/>
          </div>
          <div class="form-group">
            <label>Max Team Size</label>
            <input type="number" name="teamMax" value="4" min="1"/>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Registration Deadline</label>
            <input type="date" name="registrationDeadline"/>
          </div>
          <div class="form-group">
            <label>Start Date</label>
            <input type="date" name="startDate"/>
          </div>
          <div class="form-group">
            <label>End Date</label>
            <input type="date" name="endDate"/>
          </div>
        </div>
      </div>

      <div class="form-section">
        <h3>Prizes <button type="button" class="btn btn-outline btn-sm" onclick="addPrize()">+ Add Prize</button></h3>
        <div id="prizes-container">
          <div class="prize-row">
            <input type="text" name="prize_position" placeholder="1st Place"/>
            <input type="text" name="prize_amount" placeholder="₹50,000"/>
            <input type="text" name="prize_desc" placeholder="Description"/>
            <button type="button" class="btn-remove" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>
          </div>
        </div>
      </div>

      <div class="form-section">
        <h3>Stages <button type="button" class="btn btn-outline btn-sm" onclick="addStage()">+ Add Stage</button></h3>
        <div id="stages-container">
          <div class="stage-row">
            <input type="text" name="stage_title" placeholder="Stage Title (e.g. Round 1)"/>
            <textarea name="stage_desc" placeholder="Stage description" rows="2"></textarea>
            <div class="stage-dates-row">
              <input type="date" name="stage_start"/>
              <input type="date" name="stage_end"/>
            </div>
            <button type="button" class="btn-remove" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>
          </div>
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-lg">Publish Competition</button>
    </form>
  </div>
</div>

<script>
function addPrize() {
  const div = document.createElement('div');
  div.className = 'prize-row';
  div.innerHTML = `<input type="text" name="prize_position" placeholder="Position"/><input type="text" name="prize_amount" placeholder="Amount"/><input type="text" name="prize_desc" placeholder="Description"/><button type="button" class="btn-remove" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>`;
  document.getElementById('prizes-container').appendChild(div);
}
function addStage() {
  const div = document.createElement('div');
  div.className = 'stage-row';
  div.innerHTML = `<input type="text" name="stage_title" placeholder="Stage Title"/><textarea name="stage_desc" placeholder="Description" rows="2"></textarea><div class="stage-dates-row"><input type="date" name="stage_start"/><input type="date" name="stage_end"/></div><button type="button" class="btn-remove" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>`;
  document.getElementById('stages-container').appendChild(div);
}
</script>

<%- include('../partials/footer') %>
