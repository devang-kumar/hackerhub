<%- include('../partials/header', { title: 'My Jobs', error: messages.error, success: messages.success }) %>

<div class="page-container">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:30px;">
    <h1>My Job Postings</h1>
    <a href="/jobs/create" class="btn btn-primary"><i class="fas fa-plus"></i> Post New Job</a>
  </div>

  <% if (jobs.length === 0) { %>
    <div class="empty-state"><i class="fas fa-briefcase"></i><p>No jobs posted yet</p></div>
  <% } %>

  <div class="jobs-full-list">
    <% jobs.forEach(j => { %>
    <div class="job-card-full">
      <div class="job-left">
        <div class="company-logo"><%= j.company.charAt(0) %></div>
        <div class="job-details">
          <h3><a href="/jobs/<%= j._id %>"><%= j.title %></a></h3>
          <p class="company"><i class="fas fa-building"></i> <%= j.company %></p>
          <div class="job-tags">
            <span class="badge"><%= j.type %></span>
            <span class="badge badge-<%= j.status %>"><%= j.status %></span>
            <span class="badge"><i class="fas fa-users"></i> <%= j.applications.length %> applications</span>
          </div>
        </div>
      </div>
      <div class="job-right" style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;">
        <a href="/jobs/<%= j._id %>/manage" class="btn btn-outline btn-sm">Manage</a>
        <a href="/jobs/<%= j._id %>/edit" class="btn btn-outline btn-sm"><i class="fas fa-edit"></i> Edit</a>
        <form action="/jobs/<%= j._id %>/toggle-status" method="POST" style="display:inline">
          <button type="submit" class="btn btn-outline btn-sm"><%= j.status === 'active' ? 'Close' : 'Reopen' %></button>
        </form>
        <form action="/jobs/<%= j._id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this job and all its applications?')">
          <button type="submit" class="btn btn-sm" style="background:#fee2e2;color:#dc2626;border-color:#fecaca"><i class="fas fa-trash"></i></button>
        </form>
      </div>
    </div>
    <% }) %>
  </div>
</div>

<%- include('../partials/footer') %>
