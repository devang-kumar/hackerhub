<%- include('../partials/header', { title: 'Organizer Dashboard', error: messages.error, success: messages.success }) %>

<div class="page-container">
  <div class="dash-header">
    <div>
      <h1>Organizer Dashboard 🚀</h1>
      <p style="color:var(--text-muted)">Manage your competitions, jobs, and applicants</p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap;">
      <a href="/competitions/create" class="btn btn-outline btn-sm"><i class="fas fa-trophy"></i> New Competition</a>
      <a href="/jobs/create" class="btn btn-outline btn-sm"><i class="fas fa-briefcase"></i> Post Job</a>
      <a href="/assessments/create" class="btn btn-primary btn-sm"><i class="fas fa-clipboard-check"></i> New Assessment</a>
    </div>
  </div>

  <!-- Stats -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon" style="background:#ede9fe"><i class="fas fa-briefcase" style="color:#7c3aed"></i></div>
      <div><div class="stat-val"><%= stats.jobs %></div><div class="stat-label">Jobs Posted</div></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#dbeafe"><i class="fas fa-trophy" style="color:#2563eb"></i></div>
      <div><div class="stat-val"><%= stats.competitions %></div><div class="stat-label">Competitions</div></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#d1fae5"><i class="fas fa-file-alt" style="color:#059669"></i></div>
      <div><div class="stat-val"><%= stats.totalApplications %></div><div class="stat-label">Applications</div></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#fef3c7"><i class="fas fa-users" style="color:#d97706"></i></div>
      <div><div class="stat-val"><%= stats.teams %></div><div class="stat-label">Teams Registered</div></div>
    </div>
  </div>

  <div class="dash-grid-3">

    <!-- Recent Applications -->
    <div class="dash-section" style="grid-column:1/3">
      <div class="dash-section-header">
        <h2><i class="fas fa-inbox"></i> Recent Applications</h2>
      </div>
      <% if (recentApplications.length === 0) { %>
        <div class="empty-state" style="padding:30px"><i class="fas fa-inbox"></i><p>No applications yet</p></div>
      <% } else { %>
      <div style="overflow-x:auto">
        <table class="manage-table">
          <thead><tr><th>Applicant</th><th>Email</th><th>Job</th><th>Skills</th><th>Assessment</th><th>Status</th><th>Action</th></tr></thead>
          <tbody>
            <% recentApplications.forEach(app => { %>
            <tr>
              <td><strong><%= app.applicant.name %></strong></td>
              <td style="font-size:0.82rem"><%= app.applicant.email %></td>
              <td><a href="/jobs/<%= app.job._id %>"><%= app.job.title %></a></td>
              <td style="font-size:0.82rem"><%= (app.applicant.skills || []).slice(0,3).join(', ') || '—' %></td>
              <td><%= app.assessmentCompleted ? app.assessmentScore + ' pts' : '—' %></td>
              <td><span class="badge badge-<%= app.status %>"><%= app.status %></span></td>
              <td>
                <form action="/jobs/applications/<%= app._id %>/status" method="POST" style="display:flex;gap:4px">
                  <select name="status" style="padding:4px 6px;font-size:0.8rem;border-radius:6px;border:1px solid var(--border)">
                    <option value="applied" <%= app.status==='applied'?'selected':'' %>>Applied</option>
                    <option value="shortlisted" <%= app.status==='shortlisted'?'selected':'' %>>Shortlisted</option>
                    <option value="rejected" <%= app.status==='rejected'?'selected':'' %>>Rejected</option>
                    <option value="hired" <%= app.status==='hired'?'selected':'' %>>Hired</option>
                  </select>
                  <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

    <!-- My Jobs -->
    <div class="dash-section">
      <div class="dash-section-header">
        <h2><i class="fas fa-briefcase"></i> My Jobs</h2>
        <a href="/jobs/my-jobs" class="btn btn-outline btn-sm">View All</a>
      </div>
      <% if (jobs.length === 0) { %>
        <div class="empty-state" style="padding:20px"><p>No jobs posted yet</p></div>
      <% } else { %>
      <div class="dash-list">
        <% jobs.slice(0,5).forEach(j => { %>
        <div class="dash-item">
          <div class="dash-item-left">
            <div class="dash-item-icon"><%= j.company.charAt(0) %></div>
            <div>
              <div class="dash-item-title"><a href="/jobs/<%= j._id %>" style="color:inherit"><%= j.title %></a></div>
              <div class="dash-item-sub"><%= j.company %> &bull; <span class="badge badge-<%= j.status %>" style="font-size:0.7rem"><%= j.status %></span></div>
            </div>
          </div>
          <div class="dash-item-right">
            <div style="font-size:0.82rem;color:var(--text-muted)"><%= j.applications.length %> apps</div>
            <a href="/jobs/<%= j._id %>/manage" class="btn btn-outline btn-sm" style="margin-top:4px">Manage</a>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- My Competitions -->
    <div class="dash-section">
      <div class="dash-section-header">
        <h2><i class="fas fa-trophy"></i> My Competitions</h2>
        <a href="/competitions/my" class="btn btn-outline btn-sm">View All</a>
      </div>
      <% if (competitions.length === 0) { %>
        <div class="empty-state" style="padding:20px"><p>No competitions yet</p></div>
      <% } else { %>
      <div class="dash-list">
        <% competitions.slice(0,5).forEach(c => { %>
        <div class="dash-item">
          <div class="dash-item-left">
            <div class="dash-item-icon" style="background:linear-gradient(135deg,#f59e0b,#ef4444)"><i class="fas fa-trophy" style="font-size:1rem"></i></div>
            <div>
              <div class="dash-item-title"><a href="/competitions/<%= c._id %>" style="color:inherit"><%= c.title %></a></div>
              <div class="dash-item-sub"><span class="badge badge-<%= c.type %>"><%= c.type %></span> &bull; <%= c.registrations.length %> teams</div>
            </div>
          </div>
          <div class="dash-item-right">
            <a href="/competitions/<%= c._id %>/edit" class="btn btn-outline btn-sm"><i class="fas fa-edit"></i></a>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- Registered Teams -->
    <div class="dash-section" style="grid-column:1/3">
      <div class="dash-section-header">
        <h2><i class="fas fa-users"></i> Registered Teams</h2>
      </div>
      <% if (teams.length === 0) { %>
        <div class="empty-state" style="padding:20px"><p>No teams registered yet</p></div>
      <% } else { %>
      <div style="overflow-x:auto">
        <table class="manage-table">
          <thead><tr><th>Team</th><th>Competition</th><th>Leader</th><th>Members</th><th>Status</th></tr></thead>
          <tbody>
            <% teams.forEach(team => { %>
            <tr>
              <td><strong><%= team.name %></strong></td>
              <td><a href="/competitions/<%= team.competition._id %>"><%= team.competition.title %></a></td>
              <td><%= team.leader.name %><br><small style="color:var(--text-muted)"><%= team.leader.email %></small></td>
              <td>
                <div style="display:flex;flex-wrap:wrap;gap:4px">
                  <% team.members.forEach(m => { %>
                  <span class="badge badge-<%= m.status %>" style="font-size:0.72rem">
                    <%= m.user ? m.user.name : m.email %> (<%= m.status %>)
                  </span>
                  <% }) %>
                  <% if (team.members.length === 0) { %><span style="color:var(--text-muted);font-size:0.82rem">Solo</span><% } %>
                </div>
              </td>
              <td><span class="badge badge-active">registered</span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

  </div>
</div>

<style>
.dash-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:30px; flex-wrap:wrap; gap:16px; }
.stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:30px; }
.stat-card { background:#fff; border:1px solid var(--border); border-radius:var(--radius); padding:20px; display:flex; align-items:center; gap:16px; }
.stat-icon { width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.3rem; flex-shrink:0; }
.stat-val { font-size:1.8rem; font-weight:800; line-height:1; }
.stat-label { font-size:0.82rem; color:var(--text-muted); margin-top:2px; }
.dash-grid-3 { display:grid; grid-template-columns:1fr 1fr; gap:24px; }
.dash-section { background:#fff; border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; }
.dash-section-header { display:flex; justify-content:space-between; align-items:center; padding:16px 20px; border-bottom:1px solid var(--border); }
.dash-section-header h2 { font-size:1rem; font-weight:700; display:flex; align-items:center; gap:8px; }
.dash-section-header h2 i { color:var(--primary); }
.dash-list { display:flex; flex-direction:column; }
.dash-item { display:flex; justify-content:space-between; align-items:center; padding:12px 20px; border-bottom:1px solid #f1f5f9; gap:12px; }
.dash-item:last-child { border-bottom:none; }
.dash-item-left { display:flex; align-items:center; gap:12px; flex:1; min-width:0; }
.dash-item-icon { width:38px; height:38px; background:linear-gradient(135deg,var(--primary),#8b5cf6); border-radius:8px; display:flex; align-items:center; justify-content:center; color:#fff; font-weight:700; font-size:0.95rem; flex-shrink:0; }
.dash-item-title { font-weight:600; font-size:0.9rem; }
.dash-item-sub { font-size:0.78rem; color:var(--text-muted); margin-top:2px; }
.dash-item-right { text-align:right; flex-shrink:0; }
@media(max-width:900px) { .stats-row{grid-template-columns:repeat(2,1fr)} .dash-grid-3{grid-template-columns:1fr} .dash-section[style*="grid-column"]{grid-column:1!important} }
</style>

<%- include('../partials/footer') %>
