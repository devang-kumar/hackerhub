<%- include('../partials/header', { title: 'Organizer Dashboard', error: messages.error, success: messages.success }) %>

<div class="page-container">

  <!-- Header -->
  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:40px;flex-wrap:wrap;gap:16px">
    <div>
      <h1 style="font-size:2.2rem;font-weight:800;color:#fff;margin-bottom:6px">Organizer Dashboard <span style="background:linear-gradient(to right,#a78bfa,#f472b6);-webkit-background-clip:text;-webkit-text-fill-color:transparent">🚀</span></h1>
      <p style="color:var(--text-muted)">Manage your competitions, jobs, and applicants</p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <a href="/competitions/create" class="btn btn-outline btn-sm"><i class="fas fa-trophy"></i> New Competition</a>
      <a href="/jobs/create" class="btn btn-outline btn-sm"><i class="fas fa-briefcase"></i> Post Job</a>
      <a href="/assessments/create" class="btn btn-primary btn-sm"><i class="fas fa-clipboard-check"></i> New Assessment</a>
    </div>
  </div>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:40px">
    <div style="background:rgba(139,92,246,0.1);border:1px solid rgba(139,92,246,0.2);border-radius:16px;padding:24px;display:flex;align-items:center;gap:16px">
      <div style="width:48px;height:48px;background:rgba(139,92,246,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#a78bfa"><i class="fas fa-briefcase"></i></div>
      <div><div style="font-size:2rem;font-weight:800;color:#fff;line-height:1"><%= stats.jobs %></div><div style="font-size:0.8rem;color:var(--text-muted);margin-top:2px">Jobs Posted</div></div>
    </div>
    <div style="background:rgba(59,130,246,0.1);border:1px solid rgba(59,130,246,0.2);border-radius:16px;padding:24px;display:flex;align-items:center;gap:16px">
      <div style="width:48px;height:48px;background:rgba(59,130,246,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#93c5fd"><i class="fas fa-trophy"></i></div>
      <div><div style="font-size:2rem;font-weight:800;color:#fff;line-height:1"><%= stats.competitions %></div><div style="font-size:0.8rem;color:var(--text-muted);margin-top:2px">Competitions</div></div>
    </div>
    <div style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2);border-radius:16px;padding:24px;display:flex;align-items:center;gap:16px">
      <div style="width:48px;height:48px;background:rgba(16,185,129,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#6ee7b7"><i class="fas fa-file-alt"></i></div>
      <div><div style="font-size:2rem;font-weight:800;color:#fff;line-height:1"><%= stats.totalApplications %></div><div style="font-size:0.8rem;color:var(--text-muted);margin-top:2px">Applications</div></div>
    </div>
    <div style="background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2);border-radius:16px;padding:24px;display:flex;align-items:center;gap:16px">
      <div style="width:48px;height:48px;background:rgba(245,158,11,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fcd34d"><i class="fas fa-users"></i></div>
      <div><div style="font-size:2rem;font-weight:800;color:#fff;line-height:1"><%= stats.teams %></div><div style="font-size:0.8rem;color:var(--text-muted);margin-top:2px">Teams Registered</div></div>
    </div>
  </div>

  <!-- Recent Applications (full width) -->
  <div style="background:rgba(30,41,59,0.4);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.08);border-radius:20px;overflow:hidden;margin-bottom:24px">
    <div style="display:flex;justify-content:space-between;align-items:center;padding:20px 24px;border-bottom:1px solid rgba(255,255,255,0.06)">
      <h2 style="font-size:1rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px"><i class="fas fa-inbox" style="color:var(--primary-light)"></i> Recent Applications</h2>
    </div>
    <% if (recentApplications.length === 0) { %>
      <div style="text-align:center;padding:40px;color:var(--text-muted)">
        <i class="fas fa-inbox" style="font-size:2.5rem;opacity:0.3;display:block;margin-bottom:12px"></i>
        <p>No applications yet</p>
      </div>
    <% } else { %>
    <div style="overflow-x:auto">
      <table style="width:100%;border-collapse:collapse">
        <thead>
          <tr style="background:rgba(0,0,0,0.2)">
            <th style="padding:12px 20px;text-align:left;font-size:0.78rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px">Applicant</th>
            <th style="padding:12px 20px;text-align:left;font-size:0.78rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px">Job</th>
            <th style="padding:12px 20px;text-align:left;font-size:0.78rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px">Skills</th>
            <th style="padding:12px 20px;text-align:left;font-size:0.78rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px">Assessment</th>
            <th style="padding:12px 20px;text-align:left;font-size:0.78rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px">Status</th>
            <th style="padding:12px 20px;text-align:left;font-size:0.78rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px">Action</th>
          </tr>
        </thead>
        <tbody>
          <% recentApplications.forEach(app => { %>
          <tr style="border-top:1px solid rgba(255,255,255,0.04);transition:background 0.2s" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
            <td style="padding:14px 20px">
              <div style="font-weight:600;color:#fff;font-size:0.9rem"><%= app.applicant.name %></div>
              <div style="font-size:0.78rem;color:var(--text-muted)"><%= app.applicant.email %></div>
            </td>
            <td style="padding:14px 20px"><a href="/jobs/<%= app.job._id %>" style="color:var(--primary-light);font-size:0.9rem"><%= app.job.title %></a></td>
            <td style="padding:14px 20px;font-size:0.82rem;color:var(--text-muted)"><%= (app.applicant.skills||[]).slice(0,3).join(', ')||'—' %></td>
            <td style="padding:14px 20px;font-size:0.85rem;color:<%= app.assessmentCompleted?'#6ee7b7':'var(--text-muted)' %>"><%= app.assessmentCompleted ? app.assessmentScore+' pts' : '—' %></td>
            <td style="padding:14px 20px"><span class="badge badge-<%= app.status %>"><%= app.status %></span></td>
            <td style="padding:14px 20px">
              <form action="/jobs/applications/<%= app._id %>/status" method="POST" style="display:flex;gap:6px;align-items:center">
                <select name="status" style="padding:6px 10px;font-size:0.8rem;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:rgba(0,0,0,0.4);color:#fff;min-width:110px">
                  <option value="applied" <%= app.status==='applied'?'selected':'' %>>Applied</option>
                  <option value="shortlisted" <%= app.status==='shortlisted'?'selected':'' %>>Shortlisted</option>
                  <option value="rejected" <%= app.status==='rejected'?'selected':'' %>>Rejected</option>
                  <option value="hired" <%= app.status==='hired'?'selected':'' %>>Hired</option>
                </select>
                <button type="submit" class="btn btn-primary btn-sm">Save</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- Jobs + Competitions row -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px">

    <!-- My Jobs -->
    <div style="background:rgba(30,41,59,0.4);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.08);border-radius:20px;overflow:hidden">
      <div style="display:flex;justify-content:space-between;align-items:center;padding:20px 24px;border-bottom:1px solid rgba(255,255,255,0.06)">
        <h2 style="font-size:1rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px"><i class="fas fa-briefcase" style="color:var(--primary-light)"></i> My Jobs</h2>
        <a href="/jobs/my-jobs" class="btn btn-outline btn-sm">View All</a>
      </div>
      <% if (jobs.length === 0) { %>
        <div style="text-align:center;padding:30px;color:var(--text-muted)"><p>No jobs posted yet</p><a href="/jobs/create" class="btn btn-primary btn-sm" style="margin-top:12px">Post a Job</a></div>
      <% } else { %>
        <% jobs.slice(0,5).forEach(j => { %>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:14px 24px;border-bottom:1px solid rgba(255,255,255,0.04);gap:12px;transition:background 0.2s" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
          <div style="display:flex;align-items:center;gap:12px;flex:1;min-width:0">
            <div style="width:38px;height:38px;background:linear-gradient(135deg,rgba(139,92,246,0.3),rgba(30,41,59,0.5));border:1px solid rgba(255,255,255,0.1);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.85rem;flex-shrink:0"><%= j.company.charAt(0).toUpperCase() %></div>
            <div style="min-width:0">
              <div style="font-weight:600;color:#fff;font-size:0.88rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><a href="/jobs/<%= j._id %>" style="color:#fff"><%= j.title %></a></div>
              <div style="font-size:0.75rem;color:var(--text-muted);margin-top:2px"><%= j.company %> &bull; <span class="badge badge-<%= j.status %>" style="font-size:0.65rem;padding:2px 6px"><%= j.status %></span></div>
            </div>
          </div>
          <div style="text-align:right;flex-shrink:0">
            <div style="font-size:0.75rem;color:var(--text-muted)"><%= j.applications.length %> apps</div>
            <a href="/jobs/<%= j._id %>/manage" class="btn btn-outline btn-sm" style="margin-top:4px;font-size:0.75rem;padding:4px 10px">Manage</a>
          </div>
        </div>
        <% }) %>
      <% } %>
    </div>

    <!-- My Competitions -->
    <div style="background:rgba(30,41,59,0.4);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.08);border-radius:20px;overflow:hidden">
      <div style="display:flex;justify-content:space-between;align-items:center;padding:20px 24px;border-bottom:1px solid rgba(255,255,255,0.06)">
        <h2 style="font-size:1rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px"><i class="fas fa-trophy" style="color:#fcd34d"></i> My Competitions</h2>
        <a href="/competitions/my" class="btn btn-outline btn-sm">View All</a>
      </div>
      <% if (competitions.length === 0) { %>
        <div style="text-align:center;padding:30px;color:var(--text-muted)"><p>No competitions yet</p><a href="/competitions/create" class="btn btn-primary btn-sm" style="margin-top:12px">Create One</a></div>
      <% } else { %>
        <% competitions.slice(0,5).forEach(c => { %>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:14px 24px;border-bottom:1px solid rgba(255,255,255,0.04);gap:12px;transition:background 0.2s" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
          <div style="display:flex;align-items:center;gap:12px;flex:1;min-width:0">
            <div style="width:38px;height:38px;background:linear-gradient(135deg,rgba(245,158,11,0.3),rgba(239,68,68,0.2));border:1px solid rgba(245,158,11,0.2);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fcd34d;font-size:0.9rem;flex-shrink:0"><i class="fas fa-trophy"></i></div>
            <div style="min-width:0">
              <div style="font-weight:600;color:#fff;font-size:0.88rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><a href="/competitions/<%= c._id %>" style="color:#fff"><%= c.title %></a></div>
              <div style="font-size:0.75rem;color:var(--text-muted);margin-top:2px"><span class="badge badge-<%= c.type %>" style="font-size:0.65rem;padding:2px 6px"><%= c.type %></span> &bull; <%= c.registrations.length %> teams</div>
            </div>
          </div>
          <a href="/competitions/<%= c._id %>/edit" class="btn btn-outline btn-sm" style="font-size:0.75rem;padding:4px 10px"><i class="fas fa-edit"></i></a>
        </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- Registered Teams (full width) -->
  <div style="background:rgba(30,41,59,0.4);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.08);border-radius:20px;overflow:hidden">
    <div style="padding:20px 24px;border-bottom:1px solid rgba(255,255,255,0.06)">
      <h2 style="font-size:1rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px"><i class="fas fa-users" style="color:var(--primary-light)"></i> Registered Teams</h2>
    </div>
    <% if (teams.length === 0) { %>
      <div style="text-align:center;padding:40px;color:var(--text-muted)"><i class="fas fa-users" style="font-size:2.5rem;opacity:0.3;display:block;margin-bottom:12px"></i><p>No teams registered yet</p></div>
    <% } else { %>
    <div style="overflow-x:auto">
      <table style="width:100%;border-collapse:collapse">
        <thead>
          <tr style="background:rgba(0,0,0,0.2)">
            <th style="padding:12px 20px;text-align:left;font-size:0.78rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px">Team</th>
            <th style="padding:12px 20px;text-align:left;font-size:0.78rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px">Competition</th>
            <th style="padding:12px 20px;text-align:left;font-size:0.78rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px">Leader</th>
            <th style="padding:12px 20px;text-align:left;font-size:0.78rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px">Members</th>
          </tr>
        </thead>
        <tbody>
          <% teams.forEach(team => { %>
          <tr style="border-top:1px solid rgba(255,255,255,0.04);transition:background 0.2s" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
            <td style="padding:14px 20px;font-weight:600;color:#fff;font-size:0.9rem"><%= team.name %></td>
            <td style="padding:14px 20px"><a href="/competitions/<%= team.competition._id %>" style="color:var(--primary-light);font-size:0.9rem"><%= team.competition.title %></a></td>
            <td style="padding:14px 20px">
              <div style="font-size:0.88rem;color:#fff"><%= team.leader.name %></div>
              <div style="font-size:0.75rem;color:var(--text-muted)"><%= team.leader.email %></div>
            </td>
            <td style="padding:14px 20px">
              <div style="display:flex;flex-wrap:wrap;gap:4px">
                <% team.members.forEach(m => { %>
                <span class="badge badge-<%= m.status %>" style="font-size:0.72rem">
                  <%= m.user ? m.user.name : m.email %> (<%= m.status %>)
                </span>
                <% }) %>
                <% if (team.members.length === 0) { %><span style="color:var(--text-muted);font-size:0.82rem">Solo</span><% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

</div>

<style>
@media(max-width:900px){
  div[style*="grid-template-columns:repeat(4,1fr)"]{grid-template-columns:repeat(2,1fr)!important}
  div[style*="grid-template-columns:1fr 1fr"]{grid-template-columns:1fr!important}
}
</style>

<%- include('../partials/footer') %>
