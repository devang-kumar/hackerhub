<%- include('../partials/header', { title: 'My Dashboard', error: messages.error, success: messages.success }) %>

<div class="page-container">

  <!-- Header -->
  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:40px;flex-wrap:wrap;gap:16px">
    <div>
      <h1 style="font-size:2.2rem;font-weight:800;color:#fff;margin-bottom:6px">Welcome back, <span style="background:linear-gradient(to right,#a78bfa,#f472b6);-webkit-background-clip:text;-webkit-text-fill-color:transparent"><%= session.userName %></span> 👋</h1>
      <p style="color:var(--text-muted)">Track your applications and competitions from here</p>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <a href="/competitions" class="btn btn-outline btn-sm"><i class="fas fa-trophy"></i> Browse Competitions</a>
      <a href="/jobs" class="btn btn-primary btn-sm"><i class="fas fa-briefcase"></i> Browse Jobs</a>
    </div>
  </div>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:40px">
    <div style="background:rgba(139,92,246,0.1);border:1px solid rgba(139,92,246,0.2);border-radius:16px;padding:24px;display:flex;align-items:center;gap:16px">
      <div style="width:48px;height:48px;background:rgba(139,92,246,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#a78bfa"><i class="fas fa-file-alt"></i></div>
      <div><div style="font-size:2rem;font-weight:800;color:#fff;line-height:1"><%= stats.totalApplications %></div><div style="font-size:0.8rem;color:var(--text-muted);margin-top:2px">Applications</div></div>
    </div>
    <div style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2);border-radius:16px;padding:24px;display:flex;align-items:center;gap:16px">
      <div style="width:48px;height:48px;background:rgba(16,185,129,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#6ee7b7"><i class="fas fa-check-circle"></i></div>
      <div><div style="font-size:2rem;font-weight:800;color:#fff;line-height:1"><%= stats.shortlisted %></div><div style="font-size:0.8rem;color:var(--text-muted);margin-top:2px">Shortlisted</div></div>
    </div>
    <div style="background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2);border-radius:16px;padding:24px;display:flex;align-items:center;gap:16px">
      <div style="width:48px;height:48px;background:rgba(245,158,11,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fcd34d"><i class="fas fa-star"></i></div>
      <div><div style="font-size:2rem;font-weight:800;color:#fff;line-height:1"><%= stats.hired %></div><div style="font-size:0.8rem;color:var(--text-muted);margin-top:2px">Hired</div></div>
    </div>
    <div style="background:rgba(59,130,246,0.1);border:1px solid rgba(59,130,246,0.2);border-radius:16px;padding:24px;display:flex;align-items:center;gap:16px">
      <div style="width:48px;height:48px;background:rgba(59,130,246,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#93c5fd"><i class="fas fa-users"></i></div>
      <div><div style="font-size:2rem;font-weight:800;color:#fff;line-height:1"><%= stats.competitions %></div><div style="font-size:0.8rem;color:var(--text-muted);margin-top:2px">Competitions</div></div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">

    <!-- Job Applications -->
    <div style="background:rgba(30,41,59,0.4);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.08);border-radius:20px;overflow:hidden">
      <div style="display:flex;justify-content:space-between;align-items:center;padding:20px 24px;border-bottom:1px solid rgba(255,255,255,0.06)">
        <h2 style="font-size:1rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px"><i class="fas fa-briefcase" style="color:var(--primary-light)"></i> Job Applications</h2>
        <a href="/jobs" class="btn btn-outline btn-sm">Browse More</a>
      </div>
      <% if (applications.length === 0) { %>
        <div style="text-align:center;padding:40px;color:var(--text-muted)">
          <i class="fas fa-file-alt" style="font-size:2.5rem;opacity:0.3;display:block;margin-bottom:12px"></i>
          <p>No applications yet.</p><a href="/jobs" style="color:var(--primary-light)">Browse jobs</a>
        </div>
      <% } else { %>
        <div>
          <% applications.forEach(app => { %>
          <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 24px;border-bottom:1px solid rgba(255,255,255,0.04);gap:12px;transition:background 0.2s" onmouseover="this.style.background='rgba(255,255,255,0.03)'" onmouseout="this.style.background='transparent'">
            <div style="display:flex;align-items:center;gap:12px;flex:1;min-width:0">
              <div style="width:40px;height:40px;background:linear-gradient(135deg,rgba(139,92,246,0.3),rgba(30,41,59,0.5));border:1px solid rgba(255,255,255,0.1);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.9rem;flex-shrink:0"><%= app.job ? app.job.company.charAt(0).toUpperCase() : '?' %></div>
              <div style="min-width:0">
                <div style="font-weight:600;color:#fff;font-size:0.9rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= app.job ? app.job.title : 'Job Deleted' %></div>
                <div style="font-size:0.78rem;color:var(--text-muted)"><%= app.job ? app.job.company : '' %></div>
                <div style="margin-top:4px;display:flex;gap:4px;flex-wrap:wrap">
                  <span class="badge badge-<%= app.status %>"><%= app.status %></span>
                  <% if (app.assessmentCompleted) { %><span class="badge badge-exam">Score: <%= app.assessmentScore %></span><% } %>
                </div>
              </div>
            </div>
            <div style="text-align:right;flex-shrink:0">
              <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:6px"><%= new Date(app.appliedAt).toLocaleDateString() %></div>
              <% if (app.job) { %><a href="/jobs/<%= app.job._id %>" class="btn btn-outline btn-sm">View</a><% } %>
            </div>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Competitions -->
    <div style="background:rgba(30,41,59,0.4);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.08);border-radius:20px;overflow:hidden">
      <div style="display:flex;justify-content:space-between;align-items:center;padding:20px 24px;border-bottom:1px solid rgba(255,255,255,0.06)">
        <h2 style="font-size:1rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px"><i class="fas fa-trophy" style="color:#fcd34d"></i> My Competitions</h2>
        <a href="/competitions" class="btn btn-outline btn-sm">Browse More</a>
      </div>
      <% if (teams.length === 0) { %>
        <div style="text-align:center;padding:40px;color:var(--text-muted)">
          <i class="fas fa-trophy" style="font-size:2.5rem;opacity:0.3;display:block;margin-bottom:12px"></i>
          <p>Not in any competition yet.</p><a href="/competitions" style="color:var(--primary-light)">Explore</a>
        </div>
      <% } else { %>
        <div>
          <% teams.forEach(team => { %>
          <div style="padding:16px 24px;border-bottom:1px solid rgba(255,255,255,0.04)">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px">
              <div>
                <div style="font-weight:700;color:#fff;font-size:0.95rem"><%= team.competition ? team.competition.title : 'Competition Deleted' %></div>
                <% if (team.competition) { %>
                <div style="margin-top:4px;display:flex;gap:4px">
                  <span class="badge badge-<%= team.competition.type %>"><%= team.competition.type %></span>
                  <span class="badge badge-<%= team.competition.status %>"><%= team.competition.status %></span>
                </div>
                <% } %>
              </div>
              <% if (team.competition) { %><a href="/competitions/<%= team.competition._id %>" class="btn btn-outline btn-sm">View</a><% } %>
            </div>
            <!-- Team box -->
            <div style="background:rgba(0,0,0,0.2);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:12px">
              <div style="font-size:0.82rem;color:var(--text-muted);margin-bottom:8px">
                <i class="fas fa-users" style="color:var(--primary-light)"></i> Team: <strong style="color:#fff"><%= team.name %></strong>
                <% if (team.leader._id.toString() === session.userId) { %><span class="badge" style="background:rgba(245,158,11,0.15);color:#fcd34d;border-color:rgba(245,158,11,0.3);margin-left:6px">You're Leader</span><% } %>
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:6px">
                <span style="background:rgba(245,158,11,0.1);color:#fcd34d;border:1px solid rgba(245,158,11,0.2);padding:3px 10px;border-radius:20px;font-size:0.75rem;display:flex;align-items:center;gap:4px">
                  <i class="fas fa-crown"></i> <%= team.leader.name %>
                </span>
                <% team.members.forEach(m => { %>
                <span style="background:<%= m.status==='accepted'?'rgba(16,185,129,0.1)':m.status==='pending'?'rgba(245,158,11,0.1)':'rgba(239,68,68,0.1)' %>;color:<%= m.status==='accepted'?'#6ee7b7':m.status==='pending'?'#fcd34d':'#fca5a5' %>;border:1px solid <%= m.status==='accepted'?'rgba(16,185,129,0.2)':m.status==='pending'?'rgba(245,158,11,0.2)':'rgba(239,68,68,0.2)' %>;padding:3px 10px;border-radius:20px;font-size:0.75rem">
                  <i class="fas fa-user"></i> <%= m.user ? m.user.name : m.email %> (<%= m.status %>)
                </span>
                <% }) %>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>

  </div>
</div>

<style>
@media(max-width:900px){
  div[style*="grid-template-columns:repeat(4,1fr)"]{grid-template-columns:repeat(2,1fr)!important}
  div[style*="grid-template-columns:1fr 1fr"]{grid-template-columns:1fr!important}
}
@media(max-width:500px){
  div[style*="grid-template-columns:repeat(4,1fr)"]{grid-template-columns:1fr 1fr!important}
}
</style>

<%- include('../partials/footer') %>
