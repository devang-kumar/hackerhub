<%- include('../partials/header', { title: 'My Dashboard', error: messages.error, success: messages.success }) %>

<div class="page-container">
  <div class="dash-header">
    <div>
      <h1>Welcome back, <%= session.userName %> 👋</h1>
      <p style="color:var(--text-muted)">Here's everything happening with your account</p>
    </div>
    <div style="display:flex;gap:10px;">
      <a href="/competitions" class="btn btn-outline"><i class="fas fa-trophy"></i> Browse Competitions</a>
      <a href="/jobs" class="btn btn-primary"><i class="fas fa-briefcase"></i> Browse Jobs</a>
    </div>
  </div>

  <!-- Stats Row -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon" style="background:#ede9fe"><i class="fas fa-file-alt" style="color:#7c3aed"></i></div>
      <div><div class="stat-val"><%= stats.totalApplications %></div><div class="stat-label">Applications</div></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#d1fae5"><i class="fas fa-check-circle" style="color:#059669"></i></div>
      <div><div class="stat-val"><%= stats.shortlisted %></div><div class="stat-label">Shortlisted</div></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#fef3c7"><i class="fas fa-star" style="color:#d97706"></i></div>
      <div><div class="stat-val"><%= stats.hired %></div><div class="stat-label">Hired</div></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background:#dbeafe"><i class="fas fa-users" style="color:#2563eb"></i></div>
      <div><div class="stat-val"><%= stats.competitions %></div><div class="stat-label">Competitions</div></div>
    </div>
  </div>

  <div class="dash-grid">
    <!-- Job Applications -->
    <div class="dash-section">
      <div class="dash-section-header">
        <h2><i class="fas fa-briefcase"></i> My Job Applications</h2>
        <a href="/jobs" class="btn btn-outline btn-sm">Browse More</a>
      </div>
      <% if (applications.length === 0) { %>
        <div class="empty-state" style="padding:30px"><i class="fas fa-file-alt"></i><p>No applications yet. <a href="/jobs">Browse jobs</a></p></div>
      <% } else { %>
        <div class="dash-list">
          <% applications.forEach(app => { %>
          <div class="dash-item">
            <div class="dash-item-left">
              <div class="dash-item-icon"><%= app.job ? app.job.company.charAt(0) : '?' %></div>
              <div>
                <div class="dash-item-title"><%= app.job ? app.job.title : 'Job Deleted' %></div>
                <div class="dash-item-sub"><%= app.job ? app.job.company : '' %> &bull; <%= app.job ? app.job.type : '' %></div>
                <div style="margin-top:4px;display:flex;gap:6px;flex-wrap:wrap;">
                  <span class="badge badge-<%= app.status %>"><%= app.status %></span>
                  <% if (app.assessmentCompleted) { %><span class="badge badge-exam"><i class="fas fa-clipboard-check"></i> Score: <%= app.assessmentScore %></span><% } %>
                </div>
              </div>
            </div>
            <div class="dash-item-right">
              <div class="dash-item-date"><%= new Date(app.appliedAt).toLocaleDateString() %></div>
              <% if (app.job) { %><a href="/jobs/<%= app.job._id %>" class="btn btn-outline btn-sm">View</a><% } %>
            </div>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Competitions / Teams -->
    <div class="dash-section">
      <div class="dash-section-header">
        <h2><i class="fas fa-trophy"></i> My Competitions</h2>
        <a href="/competitions" class="btn btn-outline btn-sm">Browse More</a>
      </div>
      <% if (teams.length === 0) { %>
        <div class="empty-state" style="padding:30px"><i class="fas fa-trophy"></i><p>Not registered in any competition yet. <a href="/competitions">Explore</a></p></div>
      <% } else { %>
        <div class="dash-list">
          <% teams.forEach(team => { %>
          <div class="dash-item" style="flex-direction:column;align-items:flex-start;gap:12px;">
            <div style="display:flex;justify-content:space-between;width:100%;align-items:flex-start;">
              <div>
                <div class="dash-item-title"><%= team.competition ? team.competition.title : 'Competition Deleted' %></div>
                <% if (team.competition) { %>
                <div class="dash-item-sub">
                  <span class="badge badge-<%= team.competition.type %>"><%= team.competition.type %></span>
                  <span class="badge badge-<%= team.competition.status %>"><%= team.competition.status %></span>
                </div>
                <% } %>
              </div>
              <% if (team.competition) { %>
              <a href="/competitions/<%= team.competition._id %>" class="btn btn-outline btn-sm">View</a>
              <% } %>
            </div>
            <div class="team-info-box">
              <div class="team-name"><i class="fas fa-users"></i> Team: <strong><%= team.name %></strong>
                <% if (team.leader._id.toString() === session.userId) { %><span class="badge" style="background:#ede9fe;color:#7c3aed;margin-left:6px">Leader</span><% } %>
              </div>
              <div class="members-chips">
                <div class="member-chip leader-chip">
                  <i class="fas fa-crown"></i> <%= team.leader.name %>
                </div>
                <% team.members.forEach(m => { %>
                <div class="member-chip <%= m.status === 'accepted' ? 'accepted-chip' : m.status === 'pending' ? 'pending-chip' : '' %>">
                  <i class="fas fa-user"></i>
                  <%= m.user ? m.user.name : m.email %>
                  <span style="font-size:0.7rem;opacity:0.8">(<%= m.status %>)</span>
                </div>
                <% }) %>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<style>
.dash-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:30px; flex-wrap:wrap; gap:16px; }
.stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:30px; }
.stat-card { background:#fff; border:1px solid var(--border); border-radius:var(--radius); padding:20px; display:flex; align-items:center; gap:16px; }
.stat-icon { width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.3rem; flex-shrink:0; }
.stat-val { font-size:1.8rem; font-weight:800; color:var(--text); line-height:1; }
.stat-label { font-size:0.82rem; color:var(--text-muted); margin-top:2px; }
.dash-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px; }
.dash-section { background:#fff; border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; }
.dash-section-header { display:flex; justify-content:space-between; align-items:center; padding:16px 20px; border-bottom:1px solid var(--border); }
.dash-section-header h2 { font-size:1rem; font-weight:700; display:flex; align-items:center; gap:8px; }
.dash-section-header h2 i { color:var(--primary); }
.dash-list { display:flex; flex-direction:column; }
.dash-item { display:flex; justify-content:space-between; align-items:center; padding:14px 20px; border-bottom:1px solid #f1f5f9; gap:12px; }
.dash-item:last-child { border-bottom:none; }
.dash-item-left { display:flex; align-items:flex-start; gap:12px; flex:1; min-width:0; }
.dash-item-icon { width:40px; height:40px; background:linear-gradient(135deg,var(--primary),#8b5cf6); border-radius:8px; display:flex; align-items:center; justify-content:center; color:#fff; font-weight:700; font-size:1rem; flex-shrink:0; }
.dash-item-title { font-weight:600; font-size:0.95rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.dash-item-sub { font-size:0.82rem; color:var(--text-muted); margin-top:2px; }
.dash-item-right { text-align:right; flex-shrink:0; }
.dash-item-date { font-size:0.78rem; color:var(--text-muted); margin-bottom:6px; }
.team-info-box { background:#f8fafc; border-radius:8px; padding:12px; width:100%; }
.team-name { font-size:0.9rem; margin-bottom:8px; }
.members-chips { display:flex; flex-wrap:wrap; gap:6px; }
.member-chip { padding:4px 10px; border-radius:20px; font-size:0.78rem; display:flex; align-items:center; gap:5px; background:#e2e8f0; color:#475569; }
.leader-chip { background:#fef3c7; color:#d97706; }
.accepted-chip { background:#d1fae5; color:#059669; }
.pending-chip { background:#fef3c7; color:#d97706; }
@media(max-width:900px) { .stats-row{grid-template-columns:repeat(2,1fr)} .dash-grid{grid-template-columns:1fr} }
@media(max-width:500px) { .stats-row{grid-template-columns:1fr 1fr} }
</style>

<%- include('../partials/footer') %>
