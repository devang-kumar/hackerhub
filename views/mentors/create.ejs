<%- include('../partials/header') %>

<div class="form-page">
  <h1>Become a Mentor</h1>
  
  <form action="/mentors/create" method="POST" class="form">
    <div class="form-section">
      <h3>Mentor Profile</h3>
      <div class="form-group">
        <label>Your Domain</label>
        <input type="text" name="domain" required placeholder="e.g. Software Engineering, Product Management">
      </div>
      <div class="form-group">
        <label>Expertise / Skills</label>
        <input type="text" name="expertise" required placeholder="e.g. React, Node.js, System Design (comma separated)">
      </div>
      <div class="form-group">
        <label>Bio</label>
        <textarea name="bio" required placeholder="Tell mentees about your experience and how you can help them."></textarea>
      </div>
      <div class="form-group">
        <label>Price per Hour (₹)</label>
        <input type="number" name="pricePerHour" value="0" placeholder="0 for Free Mentorship">
      </div>
    </div>

    <button type="submit" class="btn btn-primary btn-lg">Publish Profile</button>
  </form>
</div>

<%- include('../partials/footer') %>
