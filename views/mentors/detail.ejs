<%- include('../partials/header') %>

<div class="page-container">
  <div class="detail-layout">
    <div class="detail-main">
      <div class="profile-section" style="text-align: center; padding: 40px; margin-bottom: 30px;">
        <div class="avatar-circle" style="width: 120px; height: 120px; font-size: 3rem; margin: 0 auto 20px;">
          <%= mentor.user.name.charAt(0) %>
        </div>
        <h1 style="font-size: 2.5rem; color: #fff; margin-bottom: 10px;"><%= mentor.user.name %></h1>
        <p class="company" style="font-size: 1.2rem; justify-content: center;"><i class="fas fa-briefcase"></i> <%= mentor.domain %></p>
        
        <div class="card-meta" style="justify-content: center; font-size: 1.1rem; margin-top: 15px;">
          <span style="background: rgba(251, 191, 36, 0.1); padding: 5px 15px; border-radius: 20px; color: #fbbf24; border: 1px solid rgba(251, 191, 36, 0.3);">
            <i class="fas fa-star"></i> <%= mentor.rating %>
          </span>
          <span style="background: rgba(139, 92, 246, 0.1); padding: 5px 15px; border-radius: 20px; color: #c4b5fd; border: 1px solid rgba(139, 92, 246, 0.3);">
            <i class="fas fa-video"></i> <%= mentor.sessionsCompleted %> Sessions
          </span>
        </div>
      </div>

      <div class="content-section">
        <h3><i class="fas fa-user-tie"></i> About Mentor</h3>
        <p><%= mentor.bio %></p>
        
        <h3 style="margin-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px;"><i class="fas fa-tools"></i> Expertise</h3>
        <div class="tags-row" style="margin-top: 15px;">
          <% mentor.expertise.forEach(skill => { %>
            <span class="tag"><%= skill %></span>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="detail-sidebar">
      <div class="info-card">
        <h4>Book a Session</h4>
        <div class="prize-tag" style="font-size: 1.2rem; display: flex; justify-content: center; margin-bottom: 20px;">
          <%= mentor.pricePerHour > 0 ? '₹' + mentor.pricePerHour + '/hr' : 'Free Session' %>
        </div>
        
        <form action="/mentors/<%= mentor._id %>/book" method="POST" class="form">
          <div class="form-group" style="margin-bottom: 20px;">
            <label style="margin-bottom: 10px;">Select Available Slot</label>
            <% if (mentor.availableSlots && mentor.availableSlots.length > 0) { %>
              <div style="display: flex; flex-direction: column; gap: 10px;">
                <% mentor.availableSlots.forEach(slot => { %>
                  <label style="display: flex; align-items: center; gap: 10px; background: rgba(0,0,0,0.3); padding: 12px; border-radius: 10px; border: 1px solid <%= slot.isBooked ? 'rgba(239, 68, 68, 0.3)' : 'rgba(255,255,255,0.1)' %>; cursor: <%= slot.isBooked ? 'not-allowed' : 'pointer' %>; opacity: <%= slot.isBooked ? '0.5' : '1' %>;">
                    <input type="radio" name="slotId" value="<%= slot._id %>" <%= slot.isBooked ? 'disabled' : 'required' %>>
                    <div style="flex: 1; display: flex; justify-content: space-between;">
                      <span style="color: #fff;"><i class="fas fa-calendar-alt" style="color: var(--primary); margin-right: 5px;"></i> <%= slot.date %></span>
                      <span style="color: var(--text-muted);"><i class="fas fa-clock" style="margin-right: 5px;"></i> <%= slot.time %></span>
                    </div>
                  </label>
                <% }) %>
              </div>
            <% } else { %>
              <p style="color: var(--text-muted); text-align: center; padding: 20px;">No slots available right now.</p>
            <% } %>
          </div>

          <% if (session.userId) { %>
            <button type="submit" class="btn btn-primary btn-full btn-lg" <%= (!mentor.availableSlots || mentor.availableSlots.every(s => s.isBooked)) ? 'disabled' : '' %>>
              Confirm Booking
            </button>
          <% } else { %>
            <a href="/auth/login" class="btn btn-outline btn-full btn-lg">Login to Book</a>
          <% } %>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
