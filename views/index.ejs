<%- include('partials/header') %>

<section class="hero">
  <div class="hero-content">
    <h1>Compete. Apply. <span class="highlight">Succeed.</span></h1>
    <p>The platform for students and professionals to join hackathons, land jobs, and grow their careers.</p>
    <div class="hero-actions">
      <a href="/competitions" class="btn btn-primary btn-lg"><i class="fas fa-trophy"></i> Explore Competitions</a>
      <a href="/jobs" class="btn btn-outline btn-lg"><i class="fas fa-briefcase"></i> Browse Jobs</a>
    </div>
    <div class="hero-stats">
      <div class="stat"><span class="stat-num">500+</span><span>Competitions</span></div>
      <div class="stat"><span class="stat-num">10K+</span><span>Participants</span></div>
      <div class="stat"><span class="stat-num">200+</span><span>Companies</span></div>
    </div>
  </div>
  <div class="hero-image">
    <div class="hero-graphic"><i class="fas fa-bolt"></i></div>
  </div>
</section>

<section class="section" style="padding-top:0">
  <div class="cards-grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px">
    <a href="/competitions" class="card" style="text-align:center;padding:40px 20px;text-decoration:none">
      <i class="fas fa-trophy" style="font-size:3rem;color:#ec4899;margin-bottom:20px;display:block"></i>
      <h3 style="margin-bottom:8px">Compete</h3>
      <p style="color:var(--text-muted);font-size:0.9rem">Win hackathons and hiring challenges</p>
    </a>
    <a href="/jobs?type=internship" class="card" style="text-align:center;padding:40px 20px;text-decoration:none">
      <i class="fas fa-graduation-cap" style="font-size:3rem;color:#8b5cf6;margin-bottom:20px;display:block"></i>
      <h3 style="margin-bottom:8px">Internships</h3>
      <p style="color:var(--text-muted);font-size:0.9rem">Find the best internship opportunities</p>
    </a>
    <a href="/jobs" class="card" style="text-align:center;padding:40px 20px;text-decoration:none">
      <i class="fas fa-briefcase" style="font-size:3rem;color:#3b82f6;margin-bottom:20px;display:block"></i>
      <h3 style="margin-bottom:8px">Jobs</h3>
      <p style="color:var(--text-muted);font-size:0.9rem">Apply for top full-time placements</p>
    </a>
    <a href="/competitions?type=quiz" class="card" style="text-align:center;padding:40px 20px;text-decoration:none">
      <i class="fas fa-brain" style="font-size:3rem;color:#10b981;margin-bottom:20px;display:block"></i>
      <h3 style="margin-bottom:8px">Quizzes</h3>
      <p style="color:var(--text-muted);font-size:0.9rem">Test your knowledge and win prizes</p>
    </a>
  </div>
</section>

<section class="section section-alt">
  <div class="section-header"><h2>Featured Competitions</h2><a href="/competitions" class="btn btn-outline">View All</a></div>
  <div class="cards-grid">
    <% if (!competitions || competitions.length === 0) { %>
      <p class="empty-msg" style="grid-column:1/-1">No competitions yet. <% if (session && session.role === 'organizer') { %><a href="/competitions/create">Create one!</a><% } %></p>
    <% } else { %>
      <% competitions.forEach(c => { %>
      <div class="card">
        <% if (c.banner) { %><img src="<%= c.banner %>" class="card-banner" alt="banner"><% } else { %><div class="card-banner-placeholder"><i class="fas fa-code"></i></div><% } %>
        <div class="card-body">
          <span class="badge badge-<%= c.type %>"><%= c.type %></span>
          <h3 class="card-title"><%= c.title %></h3>
          <p class="card-desc"><%= c.description.substring(0,100) %>...</p>
          <div class="card-meta">
            <span><i class="fas fa-users"></i> <%= c.teamSize.min %>-<%= c.teamSize.max %> members</span>
            <span><i class="fas fa-calendar"></i> <%= c.registrationDeadline ? new Date(c.registrationDeadline).toLocaleDateString() : 'Open' %></span>
          </div>
          <% if (c.prizes && c.prizes.length) { %><div class="prize-tag"><i class="fas fa-medal"></i> Prize: <%= c.prizes[0].amount %></div><% } %>
          <a href="/competitions/<%= c._id %>" class="btn btn-primary btn-sm" style="margin-top:12px;display:block;text-align:center">View Details</a>
        </div>
      </div>
      <% }) %>
    <% } %>
  </div>
</section>

<section class="section">
  <div class="section-header"><h2>Latest Jobs & Internships</h2><a href="/jobs" class="btn btn-outline">View All</a></div>
  <div class="jobs-list">
    <% if (!jobs || jobs.length === 0) { %>
      <p class="empty-msg">No jobs posted yet.</p>
    <% } else { %>
      <% jobs.forEach(j => { %>
      <div class="job-card">
        <div class="job-info">
          <h3><%= j.title %></h3>
          <p class="company"><i class="fas fa-building"></i> <%= j.company %></p>
          <div class="job-tags">
            <span class="badge"><%= j.type %></span>
            <span class="badge badge-location"><i class="fas fa-map-marker-alt"></i> <%= j.location %></span>
            <% if (j.salary && j.salary !== 'Not disclosed') { %><span class="badge badge-salary"><i class="fas fa-rupee-sign"></i> <%= j.salary %></span><% } %>
          </div>
        </div>
        <a href="/jobs/<%= j._id %>" class="btn btn-outline btn-sm">Apply Now</a>
      </div>
      <% }) %>
    <% } %>
  </div>
</section>

<section class="section cta-section">
  <div class="cta-content">
    <h2>Are you an organizer?</h2>
    <p>Post competitions, hackathons, and job openings. Reach thousands of talented individuals.</p>
    <% if (!session || !session.userId) { %>
    <a href="/auth/register" class="btn btn-primary btn-lg">Get Started as Organizer</a>
    <% } else if (session.role === 'organizer' || session.role === 'admin') { %>
    <a href="/dashboard" class="btn btn-primary btn-lg">Go to Dashboard</a>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
