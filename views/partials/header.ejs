<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= typeof title !== 'undefined' ? title + ' | HackHub' : 'HackHub - Compete. Grow. Succeed.' %></title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
</head>
<body>
<nav class="navbar">
  <div class="nav-container">
    <a href="/" class="nav-logo"><i class="fas fa-bolt"></i> HackHub</a>
    <div class="nav-links">
      <a href="/competitions">Competitions</a>
      <a href="/jobs">Jobs & Internships</a>
      <% if (session && session.userId) { %>
        <% if (session.role === 'organizer' || session.role === 'admin') { %>
          <div class="dropdown">
            <a href="#" class="dropdown-toggle">Post <i class="fas fa-chevron-down"></i></a>
            <div class="dropdown-menu">
              <a href="/competitions/create"><i class="fas fa-trophy"></i> Competition</a>
              <a href="/jobs/create"><i class="fas fa-briefcase"></i> Job / Internship</a>
              <a href="/assessments/create"><i class="fas fa-clipboard-check"></i> Assessment</a>
            </div>
          </div>
          <div class="dropdown">
            <a href="#" class="dropdown-toggle">Manage <i class="fas fa-chevron-down"></i></a>
            <div class="dropdown-menu">
              <a href="/competitions/my"><i class="fas fa-trophy"></i> My Competitions</a>
              <a href="/jobs/my-jobs"><i class="fas fa-briefcase"></i> My Jobs</a>
              <a href="/assessments/my"><i class="fas fa-clipboard"></i> My Assessments</a>
            </div>
          </div>
        <% } %>
        <div class="dropdown">
          <a href="#" class="dropdown-toggle"><i class="fas fa-user-circle"></i> <%= session.userName %> <i class="fas fa-chevron-down"></i></a>
          <div class="dropdown-menu">
            <a href="/auth/profile"><i class="fas fa-user"></i> My Profile</a>
            <a href="/jobs/my-applications"><i class="fas fa-file-alt"></i> My Applications</a>
            <a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
          </div>
        </div>
      <% } else { %>
        <a href="/auth/login" class="btn btn-outline">Login</a>
        <a href="/auth/register" class="btn btn-primary">Register</a>
      <% } %>
    </div>
    <button class="nav-toggle" onclick="document.querySelector('.nav-links').classList.toggle('open')">
      <i class="fas fa-bars"></i>
    </button>
  </div>
</nav>
<% if (typeof error !== 'undefined' && error && error.length) { %>
  <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= Array.isArray(error) ? error[0] : error %></div>
<% } %>
<% if (typeof success !== 'undefined' && success && success.length) { %>
  <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= Array.isArray(success) ? success[0] : success %></div>
<% } %>
