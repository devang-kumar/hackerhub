<%- include('../partials/header') %>

<div class="form-page">
  <h1>Create New Course</h1>
  
  <form action="/courses/create" method="POST" class="form">
    <div class="form-section">
      <h3>Basic Information</h3>
      <div class="form-group">
        <label>Course Title</label>
        <input type="text" name="title" required placeholder="e.g. Master JavaScript in 30 Days">
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" required placeholder="What will students learn?"></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Level</label>
          <select name="level">
            <option value="Beginner">Beginner</option>
            <option value="Intermediate">Intermediate</option>
            <option value="Advanced">Advanced</option>
          </select>
        </div>
        <div class="form-group">
          <label>Duration</label>
          <input type="text" name="duration" placeholder="e.g. 10 Hours">
        </div>
        <div class="form-group">
          <label>Price (₹)</label>
          <input type="number" name="price" value="0">
        </div>
      </div>
    </div>

    <div class="form-section">
      <h3>Add First Module</h3>
      <div class="form-group">
        <label>Module Title</label>
        <input type="text" name="moduleTitle" placeholder="e.g. Introduction to JS">
      </div>
      <div class="form-group">
        <label>Video URL (Optional)</label>
        <input type="text" name="videoUrl" placeholder="https://youtube.com/...">
      </div>
      <div class="form-group">
        <label>Module Content / Text</label>
        <textarea name="moduleContent" placeholder="Text instructions for this module"></textarea>
      </div>
    </div>

    <button type="submit" class="btn btn-primary btn-lg">Publish Course</button>
  </form>
</div>

<%- include('../partials/footer') %>
