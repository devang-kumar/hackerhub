<%- include('../partials/header') %>

<div class="page-container">
  <div class="page-hero">
    <h1>Learn & Grow</h1>
    <p>Upskill yourself with top-tier courses taught by industry experts.</p>
  </div>

  <div class="filter-bar">
    <div class="filter-form">
      <h3>All Courses</h3>
    </div>
    <% if (session && session.userId) { %>
      <a href="/courses/create" class="btn btn-primary"><i class="fas fa-plus"></i> Create Course</a>
    <% } %>
  </div>

  <div class="cards-grid">
    <% if (courses.length === 0) { %>
      <div class="empty-state" style="grid-column: 1/-1;">
        <i class="fas fa-book-open"></i>
        <p>No courses available right now. Check back later!</p>
      </div>
    <% } %>
    <% courses.forEach(c => { %>
    <div class="card">
      <div class="card-banner-placeholder"><i class="fas fa-play-circle"></i></div>
      <div class="card-body">
        <span class="badge badge-coding"><%= c.level %></span>
        <h3 class="card-title"><%= c.title %></h3>
        <p class="card-desc"><%= c.description.substring(0, 100) %>...</p>
        <div class="card-meta">
          <span><i class="fas fa-clock"></i> <%= c.duration || 'Flexible' %></span>
          <span><i class="fas fa-users"></i> <%= c.enrolledUsers.length %> Enrolled</span>
        </div>
        <div class="card-footer">
          <div class="prize-tag"><%= c.price > 0 ? '₹' + c.price : 'Free' %></div>
          <a href="/courses/<%= c._id %>" class="btn btn-primary btn-sm">Start Learning</a>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</div>

<%- include('../partials/footer') %>
