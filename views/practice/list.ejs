<%- include('../partials/header') %>

<div class="page-container">
  <div class="page-hero">
    <h1>Practice Coding</h1>
    <p>Sharpen your skills with competitive programming challenges.</p>
  </div>

  <div class="filter-bar">
    <div class="filter-form">
      <h3>Problem Selection</h3>
    </div>
    <% if (session && session.userId) { %>
      <a href="/practice/create" class="btn btn-primary"><i class="fas fa-plus"></i> Create Problem</a>
    <% } %>
  </div>

  <div class="cards-grid">
    <% if (problems.length === 0) { %>
      <div class="empty-state" style="grid-column: 1/-1;">
        <i class="fas fa-laptop-code"></i>
        <p>No practice problems currently available.</p>
      </div>
    <% } %>
    <% problems.forEach(p => { %>
    <div class="card">
      <div class="card-body">
        <span class="badge <%= p.difficulty === 'Easy' ? 'badge-online' : p.difficulty === 'Medium' ? 'badge-pending' : 'badge-closed' %>"><%= p.difficulty %></span>
        <h3 class="card-title" style="margin-top: 15px;"><%= p.title %></h3>
        <p class="card-desc"><%= p.description.substring(0, 80) %>...</p>
        
        <div class="tags-row" style="margin-bottom: 20px;">
          <% p.tags.slice(0,3).forEach(tag => { %>
            <span class="skill-chip"><%= tag %></span>
          <% }) %>
        </div>

        <div class="card-meta">
          <span><i class="fas fa-star" style="color: #fbbf24;"></i> <%= p.score %> Points</span>
          <span><i class="fas fa-check-circle" style="color: #4ade80;"></i> <%= p.solvers.length %> Solved</span>
        </div>

        <div class="card-footer">
          <a href="/practice/<%= p._id %>" class="btn btn-outline btn-full">Solve Challenge</a>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</div>

<%- include('../partials/footer') %>
